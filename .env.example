# ============================================================
# Payroll System — Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control.
# ============================================================

# MySQL Database Connection
# Use the IP of your DB server device (or 127.0.0.1 if running on same machine)
MYSQL_HOST=192.168.1.100
MYSQL_PORT=3306
MYSQL_USER=payroll_app
MYSQL_PASSWORD=Payroll@SecurePass123
MYSQL_DATABASE=payroll_db

# Connection Pool Settings (optional — sensible defaults built in)
# MYSQL_POOL_MIN=2
# MYSQL_POOL_MAX=10
# MYSQL_POOL_IDLE_TIMEOUT=30000

# Auth
# Secret used for signing session cookies (change this!)
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
